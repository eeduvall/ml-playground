{
    "model": "claude-sonnet-4-6",
    "thinkingMode": true,
    "outputStyle": "explanatory",
    "allowedTools": [
        "Read",
        "Write",
        "Bash",
        "Grep"
    ],
    "protectedPaths": [
        "configs/",
        "*.yaml",
        "requirements.txt"
    ],
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "ruff check ${file} 2>/dev/null || true"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "echo 'Running: ${command}'"
                    }
                ]
            }
        ]
    }
}